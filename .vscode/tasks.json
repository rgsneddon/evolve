{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "SSUCF: Configure build env",
      "type": "shell",
      "command": "powershell",
      "args": ["-ExecutionPolicy", "Bypass", "-File", "${workspaceFolder}/scripts/configure_build_env.ps1"],
      "problemMatcher": []
    },
    {
      "label": "SSUCF: Flutter doctor",
      "type": "shell",
      "command": "powershell",
      "args": ["-ExecutionPolicy", "Bypass", "-File", "${workspaceFolder}/scripts/doctor.ps1"],
      "problemMatcher": []
    },
    {
      "label": "SSUCF: Test",
      "type": "shell",
      "command": "powershell",
      "args": [
        "-ExecutionPolicy", "Bypass", "-Command",
        ". '${workspaceFolder}/scripts/lib/env.ps1'; $i = Set-BuildEnvironment; Set-Location '${workspaceFolder}'; & $i.FlutterExe test"
      ],
      "group": { "kind": "test", "isDefault": true },
      "problemMatcher": []
    },
    {
      "label": "SSUCF: Build web",
      "type": "shell",
      "command": "powershell",
      "args": ["-ExecutionPolicy", "Bypass", "-File", "${workspaceFolder}/scripts/build.ps1", "web"],
      "group": "build",
      "problemMatcher": []
    },
    {
      "label": "SSUCF: Build Windows",
      "type": "shell",
      "command": "powershell",
      "args": ["-ExecutionPolicy", "Bypass", "-File", "${workspaceFolder}/scripts/build.ps1", "windows"],
      "group": "build",
      "problemMatcher": []
    },
    {
      "label": "SSUCF: Build Android APK",
      "type": "shell",
      "command": "powershell",
      "args": ["-ExecutionPolicy", "Bypass", "-File", "${workspaceFolder}/scripts/build.ps1", "apk"],
      "group": "build",
      "problemMatcher": []
    },
    {
      "label": "SSUCF: Build all platforms",
      "type": "shell",
      "command": "powershell",
      "args": ["-ExecutionPolicy", "Bypass", "-File", "${workspaceFolder}/scripts/build_all.ps1"],
      "group": { "kind": "build", "isDefault": true },
      "problemMatcher": []
    }
  ]
}
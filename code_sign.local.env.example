# Copy to code_sign.local.env (gitignored) for Windows Authenticode signing.
# The certificate MUST chain to a CA in the Microsoft Trusted Root Program.
#
# Obtain a cert from:
#   - DigiCert, Sectigo, SSL.com (OV or EV code signing)
#   - Azure Trusted Signing: https://learn.microsoft.com/azure/trusted-signing/
#
# After purchase, export as .pfx (if using PFX mode) or install into the Windows
# certificate store (Current User > Personal) for store mode.

# --- Option A: PFX file (most common) ---
CODE_SIGN_MODE=pfx
CODE_SIGN_PFX_PATH=C:\path\to\evolve-codesign.pfx
CODE_SIGN_PFX_PASSWORD=your_pfx_password

# --- Option B: Windows certificate store ---
# CODE_SIGN_MODE=store
# CODE_SIGN_CERT_THUMBPRINT=ABCDEF1234567890...
# CODE_SIGN_CERT_SUBJECT=Evolve Chronoflux

# --- Option C: Azure Trusted Signing (cloud HSM) ---
# CODE_SIGN_MODE=azure
# AZURE_CODESIGN_DLIB_PATH=C:\TrustedSigning\Azure.CodeSigning.Dlib.dll
# AZURE_CODESIGN_METADATA_PATH=C:\TrustedSigning\metadata.json
# CODE_SIGN_TIMESTAMP_URL=http://timestamp.integrity.microsoft.com

# Optional metadata embedded in the signature
CODE_SIGN_DESCRIPTION=Evolve Chronoflux
CODE_SIGN_URL=https://rgsneddon.github.io/evolve/
CODE_SIGN_TIMESTAMP_URL=http://timestamp.digicert.com

# Optional override if signtool is not on PATH
# SIGNTOOL_PATH=C:\Program Files (x86)\Windows Kits\10\bin\10.0.26100.0\x64\signtool.exe
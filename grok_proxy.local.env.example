# Copy to grok_proxy.local.env (gitignored) for live Grok construal.
# X Developer Portal: https://console.x.com/
# xAI API keys: https://console.x.ai/

# Required for real X OAuth (not mock @evolve_mock)
# Portal checklist (fixes Android "Something went wrong" and old SSUCF name on X sign-in):
#   1. console.x.com → your app → App settings → App name: Evolve
#   2. User authentication settings → OAuth 2.0 ON
#   3. App type: Native App (required for Android evolve:// callback; Web App rejects it)
#   4. Callback URLs — add BOTH if you use Windows and Android (exact match):
#        http://127.0.0.1:8787/auth/callback
#        evolve://auth/callback
#   5. Scopes: tweet.read, users.read, offline.access
#   6. Windows: copy this file next to evolve.exe in build\windows\x64\runner\Release\
#   7. Android: rebuild APK after setting X_CLIENT_ID (scripts\build.ps1 apk)
X_CLIENT_ID=your_x_oauth_client_id
# Web App / Automated App only — leave empty for Native App (public client + PKCE)
X_CLIENT_SECRET=

# Required for live Grok field suggestions with X/web search (otherwise heuristic fallback)
XAI_API_KEY=your_xai_api_key
# Optional — xAI model for construal (default grok-2-latest; try grok-3 for newer search)
# XAI_CONSTRUAL_MODEL=grok-2-latest

# Optional — force mock Premium gate for local dev without X credentials
# GROK_PROXY_MOCK=1

# Optional — public HTTPS URL when proxy runs behind a tunnel or cloud host
# GROK_PROXY_PUBLIC_URL=https://your-proxy.example.com